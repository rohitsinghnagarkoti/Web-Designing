<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Student Timetable</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f2f2f2;
        }
        table {
            width: 80%;
            margin: 40px auto;
            border-collapse: collapse;
            background-color: white;
        }
        caption {
            font-size: 24px;
            margin: 10px;
            font-weight: bold;
        }
        th, td {
            border: 1px solid #000;
            padding: 10px;
            text-align: center;
        }
        thead {
            background-color: #333;
            color: white;
        }
        tfoot {
            background-color: #ddd;
            font-weight: bold;
        }
        tr:hover {
            background-color: #f5f5f5;
        }
    </style>
</head>
<body>

<table>
    <caption>College Timetable</caption>

    <thead>
        <tr>
            <th rowspan="2">Day</th>
            <th colspan="5">Subjects</th>
        </tr>
        <tr>
            <th>9-10</th>
            <th>10-11</th>
            <th>11-12</th>
            <th>12-1</th>
            <th>2-3</th>
        </tr>
    </thead>

    <tbody>
        <tr>
            <td>Monday</td>
            <td>Math</td>
            <td>Physics</td>
            <td rowspan="5">Break</td>
            <td>Chemistry</td>
            <td>English</td>
        </tr>
        <tr>
            <td>Tuesday</td>
            <td>Biology</td>
            <td>Math</td>
            <td>Physics</td>
            <td>Sports</td>
        </tr>
        <tr>
            <td>Wednesday</td>
            <td colspan="2">Computer Lab</td>
            <td>Chemistry</td>
            <td>English</td>
        </tr>
        <tr>
            <td>Thursday</td>
            <td>Math</td>
            <td>Biology</td>
            <td colspan="2">Project Work</td>
        </tr>
        <tr>
            <td>Friday</td>
            <td>Physics</td>
            <td>Chemistry</td>
            <td>Math</td>
            <td>Library</td>
        </tr>
    </tbody>

    <tfoot>
        <tr>
            <td colspan="6">Total Working Days: 5</td>
        </tr>
    </tfoot>

</table>

</body>
</html>
